{% load static %}
<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
	<title>{% block title %}Procurement Office{% endblock %}</title>
	<link rel="icon" type="image/jpg" href="{% static 'images/wmsu_favicon.png' %}">
	<link
		href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
		rel="stylesheet">
	<script src="https://cdn.tailwindcss.com"></script>
	<style>
		* {
			font-family: 'Inter', system-ui, -apple-system, sans-serif;
		}

		/* Custom scrollbar */
		.activity-scroll::-webkit-scrollbar {
			width: 6px;
		}

		.activity-scroll::-webkit-scrollbar-track {
			background: #f1f1f1;
			border-radius: 10px;
		}

		.activity-scroll::-webkit-scrollbar-thumb {
			background: #cbd5e1;
			border-radius: 10px;
		}

		.activity-scroll::-webkit-scrollbar-thumb:hover {
			background: #94a3b8;
		}

		/* Custom styles for active nav link */
		.nav-active {
			background-color: #fef2f2;
			border-left-color: #dc2626;
			color: #dc2626;
		}

		.nav-active svg {
			color: #dc2626;
		}

		/* Fixed Header - Stays at top always */
		.fixed-header {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 100;
			background: linear-gradient(to right, #991b1b, #b91c1c);
		}

		/* Main container with padding for fixed header */
		.main-container {
			padding-top: 73px;
			min-height: 100vh;
		}

		/* Sticky Sidebar - Scrolls with content but stays visible */
		.sidebar-wrapper {
			position: sticky;
			top: 73px;
			height: calc(100vh - 73px);
			overflow-y: auto;
		}

		/* Custom scrollbar for sidebar */
		.sidebar-wrapper::-webkit-scrollbar {
			width: 4px;
		}

		.sidebar-wrapper::-webkit-scrollbar-track {
			background: #f1f1f1;
		}

		.sidebar-wrapper::-webkit-scrollbar-thumb {
			background: #cbd5e1;
			border-radius: 4px;
		}

		.sidebar-wrapper::-webkit-scrollbar-thumb:hover {
			background: #94a3b8;
		}

		/* Desktop Sidebar - Fixed width */
		.sidebar-desktop {
			width: 280px;
			flex-shrink: 0;
			background: white;
			border-right: 1px solid #e5e7eb;
		}

		/* Mobile Sidebar */
		@media (max-width: 768px) {
			.sidebar-desktop {
				position: fixed;
				left: -280px;
				top: 73px;
				bottom: 0;
				transition: left 0.3s ease;
				z-index: 90;
				height: calc(100% - 73px);
			}
			.sidebar-desktop.open {
				left: 0;
			}
			.mobile-overlay {
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.5);
				z-index: 85;
				display: none;
				top: 73px;
			}
			.mobile-overlay.open {
				display: block;
			}
		}

		/* Dropdown animation */
		.dropdown-enter {
			transition: all 0.2s ease;
		}

		/* Responsive text sizes */
		@media (max-width: 640px) {
			.brand-title {
				font-size: 0.875rem;
			}
			.brand-subtitle {
				display: none;
			}
			.user-name {
				display: none;
			}
		}
	</style>
	{% block extra_css %}{% endblock %}
</head>

<body class="bg-gray-50">

	<!-- Mobile Menu Overlay -->
	<div id="mobile-overlay" class="mobile-overlay" onclick="closeSidebar()"></div>

	<!-- FIXED HEADER - Stays at top always -->
	<header class="fixed-header shadow-lg">
		<div class="px-4 sm:px-6 py-3 sm:py-4">
			<div class="flex items-center justify-between">
				<!-- Left side - Logo and Title + Mobile Menu Button -->
				<div class="flex items-center gap-3">
					<!-- Mobile Hamburger Menu Button (visible only on mobile) -->
					<button id="mobile-menu-btn" class="md:hidden text-white hover:text-gray-200 focus:outline-none transition-colors">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
					</button>

					<!-- Logo Image -->
					<div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full flex items-center justify-center overflow-hidden bg-white shadow-md flex-shrink-0">
						<img src="{% static 'images/wmsu_logo.png' %}" alt="WMSU Logo" class="w-full h-full object-cover">
					</div>
					
					<div>
						<h1 class="brand-title text-sm sm:text-xl font-bold text-white whitespace-nowrap">PROCUREMENT OFFICE</h1>
						<p class="brand-subtitle text-xs text-red-100 hidden sm:block">{% block header_subtitle %}Dashboard{% endblock %}</p>
					</div>
				</div>

				<!-- Right side - User Dropdown Menu -->
				<div class="relative">
					<button id="user-menu-button" class="flex items-center gap-2 focus:outline-none group">
						<div class="w-8 h-8 bg-white rounded-full flex items-center justify-center group-hover:bg-gray-100 transition shadow-sm">
							<span class="text-red-600 font-semibold text-sm">
								{{ user.first_name|slice:":1" }}{{ user.last_name|slice:":1"|default:"U" }}
							</span>
						</div>
						<span class="user-name text-sm font-medium text-white hidden md:inline">
							{% if user.is_authenticated %}
							{{ user.get_full_name|default:user.username }}
							{% else %}
							Guest User
							{% endif %}
						</span>
						<svg class="w-4 h-4 text-white transition-transform duration-200 hidden sm:block" fill="none"
							stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
						</svg>
					</button>

					<!-- Dropdown Menu -->
					<div id="user-dropdown"
						class="absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 hidden z-50">
						<div class="py-2">
							<div class="px-4 py-3 border-b border-gray-100">
								<p class="text-sm font-semibold text-gray-800">
									{% if user.is_authenticated %}
									{{ user.get_full_name|default:user.username }}
									{% else %}
									Guest User
									{% endif %}
								</p>
								<p class="text-xs text-gray-500 mt-1">
									{% if user.is_authenticated %}
									{{ user.email }}
									{% else %}
									Not signed in
									{% endif %}
								</p>
							</div>

							<a href="{% url 'users:profile' %}" class="flex items-center gap-3 px-4 py-2 text-gray-700 hover:bg-gray-50 transition">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
								</svg>
								<span class="text-sm">My Profile</span>
							</a>

							<a href="#" class="flex items-center gap-3 px-4 py-2 text-gray-700 hover:bg-gray-50 transition">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
								</svg>
								<span class="text-sm">Settings</span>
							</a>

							<div class="border-t border-gray-100 my-1"></div>

							{% if user.is_authenticated %}
							<a href="#" class="flex items-center gap-3 px-4 py-2 text-red-600 hover:bg-red-50 transition">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
								</svg>
								<span class="text-sm">Logout</span>
							</a>
							{% else %}
							<a href="#" class="flex items-center gap-3 px-4 py-2 text-red-600 hover:bg-red-50 transition">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
								</svg>
								<span class="text-sm">Login</span>
							</a>
							{% endif %}
						</div>
					</div>
				</div>
			</div>
		</div>
	</header>

	<!-- Main Container with padding for fixed header -->
	<div class="main-container">
		<div class="flex">
			
			<!-- Sidebar Navigation -->
			<aside id="sidebar" class="sidebar-desktop">
				<div class="sidebar-wrapper">
					<div class="p-6">
						<nav class="space-y-2">
							<a href="{% url 'core:dashboard' %}"
								class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition {% if request.resolver_match.url_name == 'dashboard' %}nav-active{% endif %}">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
								</svg>
								<span class="font-medium">Dashboard</span>
							</a>

							<a href="{% url 'activity_logs:list_activities' %}"
								class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
								</svg>
								<span>Activity Log</span>
							</a>

							<a href="#"
								class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
								</svg>
								<span>Request</span>
							</a>

							<a href="{% url 'inventory:list_inventory' %}"
								class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
								</svg>
								<span>Inventory</span>
							</a>

							<a href="#"
								class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
								</svg>
								<span>Invoice</span>
							</a>
						</nav>
					</div>
				</div>
			</aside>

			<!-- Main Content Area -->
			<main class="flex-1 overflow-x-hidden">
				<div class="p-4 sm:p-6 lg:p-8">
					{% block content %}
					{% endblock %}
				</div>
			</main>
		</div>
	</div>

	<!-- JavaScript for Dropdown and Mobile Sidebar -->
	<script>
		// User dropdown functionality
		const userMenuButton = document.getElementById('user-menu-button');
		const userDropdown = document.getElementById('user-dropdown');

		if (userMenuButton && userDropdown) {
			userMenuButton.addEventListener('click', (e) => {
				e.stopPropagation();
				userDropdown.classList.toggle('hidden');

				const arrowIcon = userMenuButton.querySelector('svg:last-child');
				if (arrowIcon) {
					if (userDropdown.classList.contains('hidden')) {
						arrowIcon.style.transform = 'rotate(0deg)';
					} else {
						arrowIcon.style.transform = 'rotate(180deg)';
					}
				}
			});

			document.addEventListener('click', (e) => {
				if (!userMenuButton.contains(e.target) && !userDropdown.contains(e.target)) {
					userDropdown.classList.add('hidden');
					const arrowIcon = userMenuButton.querySelector('svg:last-child');
					if (arrowIcon) {
						arrowIcon.style.transform = 'rotate(0deg)';
					}
				}
			});
		}

		// Mobile sidebar functionality
		const mobileMenuBtn = document.getElementById('mobile-menu-btn');
		const sidebar = document.getElementById('sidebar');
		const overlay = document.getElementById('mobile-overlay');

		function openSidebar() {
			if (sidebar) sidebar.classList.add('open');
			if (overlay) overlay.classList.add('open');
			document.body.style.overflow = 'hidden';
		}

		function closeSidebar() {
			if (sidebar) sidebar.classList.remove('open');
			if (overlay) overlay.classList.remove('open');
			document.body.style.overflow = '';
		}

		if (mobileMenuBtn) {
			mobileMenuBtn.addEventListener('click', openSidebar);
		}

		// Close sidebar when clicking outside on desktop
		window.addEventListener('resize', function() {
			if (window.innerWidth > 768) {
				closeSidebar();
			}
		});
	</script>

	{% block extra_js %}{% endblock %}
</body>

</html>